# ══════════════════════════════════════════════════════════════════════════════
# Bella Notte Agent — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Google Gemini API (required) ─────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# ── PersonaPlex Voice Server ─────────────────────────────────────────────────
# Default assumes PersonaPlex runs on the same machine
PERSONAPLEX_SERVER_URL=wss://localhost:8998/api/chat

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=bookings.db

# ── RAG Settings ─────────────────────────────────────────────────────────────
DOCS_FOLDER=docs
CHROMA_FOLDER=.chroma_db
EMBED_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=400
CHUNK_OVERLAP=80
RAG_TOP_K=6

# ── Restaurant Info ──────────────────────────────────────────────────────────
RESTAURANT_NAME=Bella Notte
AGENT_NAME=Sofia
CUISINE=Italian
OPENING_HOURS=Monday to Sunday, 12:00 PM to 10:00 PM
PHONE=+1-800-555-0199

# ── Voice ────────────────────────────────────────────────────────────────────
VOICE_ID=NATF1
SAMPLE_RATE=24000
CHUNK_AUDIO=1920
